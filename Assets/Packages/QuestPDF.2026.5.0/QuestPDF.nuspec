<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>QuestPDF</id>
    <version>2026.5.0</version>
    <authors>MarcinZiabek</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="file">PackageLicense.md</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <icon>Logo.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://www.questpdf.com/</projectUrl>
    <iconUrl>https://www.questpdf.com/logo.webp</iconUrl>
    <description>QuestPDF is a modern library for PDF document generation. Its fluent C# API lets you design complex layouts with clean, readable code. Create invoices, reports, and documents using a flexible, component-based approach.</description>
    <releaseNotes>- Fixed a bug where Table elements with RowSpan could render incorrectly or break when spanning across pages.
- Fixed visual rendering artifacts that could appear in complex or very large paragraphs.
- Improved error message when native dependency versions are mismatched — the error now includes step-by-step guidance for updating manually copied native files.
- Updated the underlying Skia native dependency to version m146.</releaseNotes>
    <copyright>Marcin Ziąbek, QuestPDF contributors</copyright>
    <tags>pdf generation creation export merge edit html</tags>
    <repository type="git" url="https://github.com/QuestPDF/library.git" commit="f4a9c3978a2e86b40158ab1452c1dd2c8db483d2" />
    <dependencies>
      <group targetFramework="net6.0" />
      <group targetFramework="net8.0" />
      <group targetFramework="net10.0" />
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Numerics.Vectors" version="4.6.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>